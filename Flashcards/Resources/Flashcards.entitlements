<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      CloudKit entitlements for the configurable iCloud sync. Inert until wired up:
      set a DEVELOPMENT_TEAM, switch CODE_SIGN_STYLE to Automatic, and uncomment
      CODE_SIGN_ENTITLEMENTS in project.yml. Then enable sync in Settings.
    -->
    <key>com.apple.developer.icloud-container-identifiers</key>
    <array>
        <string>iCloud.com.mike.Flashcards</string>
    </array>
    <key>com.apple.developer.icloud-services</key>
    <array>
        <string>CloudKit</string>
    </array>
</dict>
</plist>
